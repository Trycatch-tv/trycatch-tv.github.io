# ─────────────────────────────────────────────────────────────
# TryCatch Live Alerts — Variables de entorno requeridas
# ─────────────────────────────────────────────────────────────
# Copia este archivo como .env.local para desarrollo local
# En producción, configura estas variables en:
# Netlify Dashboard → Site → Environment variables
# ─────────────────────────────────────────────────────────────

# ── YouTube Data API v3 ───────────────────────────────────────
# Cómo obtenerla:
#   1. Ir a https://console.cloud.google.com/
#   2. Crear un proyecto (o usar uno existente)
#   3. Habilitar "YouTube Data API v3"
#   4. Ir a "Credenciales" → "Crear credenciales" → "Clave de API"
#   5. Restringir la clave a la API de YouTube (recomendado)
YOUTUBE_API_KEY=

# ID del canal de YouTube (empieza con UC...)
# Cómo obtenerlo:
#   Opción A: https://www.youtube.com/account_advanced
#   Opción B: En cualquier video del canal, ver el código fuente y buscar "channelId"
#   Opción C: Usar https://commentpicker.com/youtube-channel-id.php
YOUTUBE_CHANNEL_ID=

# ── OneSignal — Servidor (privado, NUNCA exponer en el cliente) ─
# Cómo obtenerlos:
#   1. Crear cuenta en https://onesignal.com
#   2. Crear una nueva app → Web → Custom Code
#   3. Configurar origen: https://trycatch.tv
#   4. Ir a Settings → Keys & IDs
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# ── OneSignal — Cliente (público, visible en el navegador) ──────
# Es el mismo App ID, pero con el prefijo PUBLIC_ para que
# Astro lo exponga al código cliente en build time.
PUBLIC_ONESIGNAL_APP_ID=

# ─────────────────────────────────────────────────────────────
# Variables existentes del proyecto (Twitch — no modificar)
# ─────────────────────────────────────────────────────────────
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_BROADCASTER_ID=
TWITCH_REFRESH_TOKEN=
