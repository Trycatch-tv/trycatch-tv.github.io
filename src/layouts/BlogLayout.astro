---
import "../styles/global.css"
import { getImage } from "astro:assets"
import Footer from "../components/global/Footer.astro"
import Navbar from "../components/global/Navbar.astro"

const { frontmatter } = Astro.props

const april2026Hero = new URL(
  "../assets/img/comunidades/bucaramanga/encuentros/abril-2026/abril 2026.JPG",
  import.meta.url,
).href

const communityImages = import.meta.glob(
  "../assets/img/comunidades/**/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG,WEBP}",
  { eager: true, import: "default" },
) as Record<string, ImageMetadata>

const normalizeFolder = (folder = "") =>
  folder.replace(/\\/g, "/").replace(/^src\//, "../").replace(/\/?$/, "/")

const normalizeAsset = (asset = "") =>
  asset.replace(/\\/g, "/").replace(/^src\//, "../")

const imageAsset = normalizeAsset(frontmatter.image?.asset)
const heroImageAsset =
  imageAsset && communityImages[imageAsset]
    ? await getImage({ src: communityImages[imageAsset] })
    : null

const heroImageSrc =
  frontmatter.slug === "meetup-soft-skills-abril-2026"
    ? april2026Hero
    : heroImageAsset?.src ?? frontmatter.image.url

const heroImageAlt = frontmatter.image?.alt ?? frontmatter.title

const photosFolder = normalizeFolder(frontmatter.photosFolder)
const galleryEntries = photosFolder.includes("/galeria/")
  ? Object.entries(communityImages)
      .filter(([path]) => path.startsWith(photosFolder))
      .sort(([a], [b]) => a.localeCompare(b))
  : []

const galleryImages = await Promise.all(
  galleryEntries.map(async ([path, src], index) => {
    const image = await getImage({ src })

    return {
      src: image.src,
      alt: `${frontmatter.title} - foto ${index + 1}`,
      name: path.split("/").pop() ?? `Foto ${index + 1}`,
    }
  }),
)
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=0.8, maximum-scale=1, user-scalable=no"
    />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <astro:head>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-1KX127N7NK"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || []
      function gtag() {
        window.dataLayer.push(arguments)
      }
      gtag("js", new Date())
      gtag("config", "G-1KX127N7NK")
    </script>
  </astro:head>
  <title>{frontmatter.title}</title>

  <body class="mt-20 font-sans">
    <Navbar />
    <div
      class="max-w-screen-2xl mx-auto bg-tc-gray-l dark:bg-white py-16 px-8 rounded-md shadow-lg"
    >
      <div class="relative h-96 overflow-hidden rounded-md shadow-inner mb-">
        <img
          class="absolute inset-0 w-full h-full object-cover object-center"
          src={heroImageSrc}
          alt={heroImageAlt}
        />
      </div>

      <h1 class="text-4xl font-bold mb-4">{frontmatter.title}</h1>
      <span class="block text-md text-tc-black-l mb-8"
        >Autor {frontmatter.author} - {
          new Date(frontmatter.date).toLocaleDateString("es-CO", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })
        }</span
      >
      <div class="border-b-2 border-gray-200 mb-8"></div>
      <div class="prose dark:prose-dark max-w-none">
        <slot />
      </div>

      {
        galleryImages.length > 0 && (
          <section class="mt-12 border-t-2 border-gray-200 pt-8">
            <h2 class="text-2xl font-bold mb-5">Galeria del encuentro</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {galleryImages.map((photo) => (
                <a
                  href={photo.src}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group block overflow-hidden rounded-md bg-white shadow-md"
                >
                  <img
                    src={photo.src}
                    alt={photo.alt}
                    loading="lazy"
                    class="h-64 w-full object-cover transition duration-200 group-hover:scale-105"
                  />
                </a>
              ))}
            </div>
          </section>
        )
      }
    </div>
    <Footer />
  </body>

  <style is:global>
    @import url("https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800&display=swap");
    html {
      font-family:
        "JetBrains Mono", monospace, system-ui, sans-serif !important;
      background-color: rgb(71 70 70);
    }
  </style>


</html>
