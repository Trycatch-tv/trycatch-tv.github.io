---
import { Image } from "astro:assets"
import CoverBucaramanga from "../assets/img/comunidades/bucaramanga/cover.jpg"
import DefaultCommunityCover from "../assets/img/comunidades/default-cover.svg"
import BaseLayout from "../layouts/BaseLayout.astro"

const comunidades = [
  {
    city: "Bucaramanga",
    status: "activa",
    description:
      "Comunidad local donde nos reunimos a hablar de tech, compartir experiencias y crecer juntos. Un espacio abierto para conectar, aprender y construir comunidad en Bucaramanga.",
    href: "/comunidades/bucaramanga",
    cover: CoverBucaramanga,
    coverAlt: "Comunidad Bucaramanga",
  },
  {
    city: "Bogota",
    status: "proximamente",
    description:
      "Estamos estructurando alianzas y agenda para comenzar actividades de comunidad.",
    href: "",
    cover: DefaultCommunityCover,
    coverAlt: "Portada por defecto de comunidad",
  },
  {
    city: "Medellin",
    status: "proximamente",
    description:
      "Proximo nodo local para eventos, divulgacion y colaboracion tecnica.",
    href: "",
    cover: DefaultCommunityCover,
    coverAlt: "Portada por defecto de comunidad",
  },
]
---

<BaseLayout title={`Comunidad Trycker`}>
  <main class="max-w-6xl mx-auto mt-24 mb-16 px-4 md:px-6">
    <section
      class="rounded-2xl border border-slate-700 bg-tc-black p-8 md:p-12 shadow-2xl lift-in"
    >
      <div>
        <h1
          class="mt-4 text-3xl md:text-5xl font-bold text-tc-yellow uppercase tracking-wide leading-tight"
        >
          Comunidad Trycker
        </h1>
        <p
          class="mt-4 text-slate-200 max-w-3xl leading-relaxed text-base md:text-lg"
        >
          Con estos espacios informales buscamos construir una verdadera tribu
          tech. Un lugar para aprender, compartir, conocer gente y crecer
          juntos, sin importar en que punto estes. Aqui vive lo que pasa en cada
          encuentro y lo que la comunidad construye dia a dia.
        </p>
      </div>
    </section>

    <section class="mt-10">
      <h2
        class="text-tc-yellow text-2xl font-bold mb-4 uppercase tracking-wide"
      >
        Ciudades
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {
          comunidades.map((comunidad) => (
            <article class="rounded-2xl border border-slate-500 bg-[#141414] p-5 shadow-lg card-hover min-h-[390px] flex flex-col">
              {comunidad.cover && (
                <div class="mb-4 overflow-hidden rounded-xl border border-slate-700">
                  <Image
                    src={comunidad.cover}
                    alt={comunidad.coverAlt || `Portada ${comunidad.city}`}
                    class="h-44 w-full object-cover"
                  />
                </div>
              )}
              <div class="flex items-center justify-between gap-2">
                <h3 class="text-xl font-semibold text-white">
                  {comunidad.city}
                </h3>
                <span
                  class={`text-xs px-2 py-1 rounded-full font-semibold tracking-wide ${
                    comunidad.status === "activa"
                      ? "bg-emerald-600/90 text-white"
                      : "bg-slate-700 text-slate-200"
                  }`}
                >
                  {comunidad.status === "activa" ? "Activa" : "Proximamente"}
                </span>
              </div>
              <p class="mt-3 text-sm text-slate-200 leading-relaxed">
                {comunidad.description}
              </p>

              {comunidad.href ? (
                <a
                  href={comunidad.href}
                  class="inline-flex items-center mt-auto pt-4 text-tc-yellow font-semibold hover:text-amber-200 transition"
                >
                  Ir a comunidad
                </a>
              ) : (
                <span class="inline-block mt-auto pt-4 text-slate-300 text-sm">
                  Pronto habilitada
                </span>
              )}
            </article>
          ))
        }
      </div>
    </section>
  </main>

  <style>
    .lift-in {
      animation: liftIn 0.55s ease-out both;
    }

    .card-hover {
      transition:
        transform 180ms ease,
        box-shadow 180ms ease,
        border-color 180ms ease;
    }

    .card-hover:hover {
      transform: translateY(-3px);
      border-color: rgba(252, 211, 77, 0.55);
      box-shadow: 0 18px 36px rgba(2, 6, 23, 0.42);
    }

    @keyframes liftIn {
      from {
        opacity: 0;
        transform: translateY(12px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>
</BaseLayout>
