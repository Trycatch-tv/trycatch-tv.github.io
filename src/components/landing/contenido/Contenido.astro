---
const info = {
  title: "Tipos de Contenido",
  description:
    "En TryCatch.tv compartimos contenido variado pensado para impulsar tu crecimiento profesional y técnico. Estos son algunos de los formatos que puedes encontrar:",
  contentTypes: [
    {
      icon: "🎥",
      title: "Videos educativos",
      description:
        "Tutoriales, análisis de herramientas y conceptos clave de desarrollo y arquitectura.",
    },
    {
      icon: "📺",
      title: "Transmisiones en vivo",
      description:
        "Sesiones interactivas con la comunidad resolviendo dudas, creando proyectos y compartiendo experiencias.",
    },
    {
      icon: "🧵",
      title: "Shorts y tips",
      description:
        "Videos breves con hacks, recomendaciones y reflexiones del mundo tech.",
    },
    {
      icon: "📚",
      title: "Lecturas en comunidad",
      description:
        "Club de lectura de libros sobre software, soft skills y liderazgo.",
    },
    {
      icon: "📣",
      title: "Divulgación y opinión",
      description:
        "Noticias, comentarios y reflexiones sobre lo que pasa en la industria de la tecnología.",
    },
    {
      icon: "🎙️",
      title: "Entrevistas",
      description:
        "Conversaciones con personas referentes del ecosistema tech sobre sus historias y aprendizajes.",
    },
  ],
}
---

<section>
  <div class="px-4 lg:mx-auto lg:max-w-screen-2xl">
    <div
      class="bg-tc-black border border-gray-700 rounded-xl p-8 lg:p-12 mb-12"
    >
      <div class="text-center mb-10">
        <span
          class="inline-block text-xs px-3 py-1 rounded-full bg-tc-black-l border border-gray-600 text-tc-yellow font-semibold tracking-wide mb-4"
        >
          FORMATO TRY CATCH
        </span>
        <h2
          class="text-white text-3xl lg:text-5xl font-extrabold mb-3 leading-tight"
        >
          {info.title}
        </h2>
        <p
          class="text-gray-300 text-base lg:text-lg max-w-3xl mx-auto leading-relaxed"
        >
          {info.description}
        </p>
      </div>

      <div
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-screen-2xl mx-auto"
      >
        {
          info.contentTypes.map((item) => (
            <article class="bg-tc-black-l border border-gray-700 rounded-lg p-6 text-center min-h-[250px] flex flex-col items-center justify-start hover:shadow-xl hover:border-gray-500 transition-all duration-200">
              <div class="w-14 h-14 rounded-full bg-tc-black border border-gray-600 flex items-center justify-center text-3xl mb-4">
                {item.icon}
              </div>
              <h3 class="text-tc-yellow font-bold text-xl mb-3 leading-snug">
                {item.title}
              </h3>
              <p class="text-gray-300 text-sm lg:text-base leading-relaxed">
                {item.description}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
