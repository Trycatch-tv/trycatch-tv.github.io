---
import { Icon } from "astro-icon"

const info = {
  feedbackText:
    "Tu experiencia nos ayuda a mejorar. Comparte sugerencias, ideas o un testimonio sobre lo que has vivido en la comunidad.",
  year: new Date().getFullYear(),
  feedbackForm: "https://bit.ly/encuesta_trycatch",
  testimonialForm: "https://bit.ly/testimoniotc",
}
---

<!-- Footer completo con contenido -->
<footer class="bg-tc-black border-t border-gray-700 pt-10 text-center px-4">
  <div class="max-w-screen-xl mx-auto grid grid-cols-1 gap-10">
    <div
      class="bg-tc-black-l border border-slate-600 rounded-xl p-6 md:p-10 hover:shadow-lg transition"
    >
      <div
        class="grid grid-cols-1 lg:grid-cols-[1.2fr_1fr] gap-8 items-center text-left"
      >
        <div>
          <div
            class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-slate-500 text-tc-yellow text-xs font-semibold tracking-wide mb-4"
          >
            <Icon class="w-4 h-4" name="mdi:message-draw" />
            PARTICIPA EN LA COMUNIDAD
          </div>
          <h3 class="text-white font-bold text-2xl leading-tight">
            Dejanos tu opinion
          </h3>
          <p class="text-gray-300 text-base mt-3 max-w-2xl leading-relaxed">
            {info.feedbackText}
          </p>
        </div>

        <div
          class="w-full grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-3"
        >
          <a
            href={info.feedbackForm}
            class="flex items-center justify-center gap-2 py-3 px-5 text-base font-semibold rounded-lg text-tc-black bg-tc-gray-l hover:bg-tc-yellow transition-transform transform hover:scale-[1.02]"
          >
            Enviar feedback
            <svg
              aria-hidden="true"
              class="w-5 h-5"
              fill="currentColor"
              viewBox="0 0 20 20"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                fill-rule="evenodd"
                d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                clip-rule="evenodd"></path>
            </svg>
          </a>

          <a
            href={info.testimonialForm}
            class="flex items-center justify-center gap-2 py-3 px-5 text-base font-semibold rounded-lg text-tc-black bg-tc-gray-l hover:bg-tc-yellow transition-transform transform hover:scale-[1.02]"
          >
            Compartir testimonio
            <svg
              aria-hidden="true"
              class="w-5 h-5"
              fill="currentColor"
              viewBox="0 0 20 20"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                fill-rule="evenodd"
                d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                clip-rule="evenodd"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Copyright -->
  <div class="mt-10 text-gray-500 text-xs">
    © {info.year} TryCatch.tv – Hecho con ❤️ desde LATAM
  </div>
</footer>
